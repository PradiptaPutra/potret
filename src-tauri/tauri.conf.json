{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "potret",
  "version": "0.1.0",
  "identifier": "com.potret.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Potret",
        "width": 900,
        "height": 620,
        "minWidth": 700,
        "minHeight": 500,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "center": true
      },
      {
        "label": "annotation",
        "title": "Potret — Annotate",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "center": true,
        "url": "annotation"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
