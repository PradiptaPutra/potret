{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all potret windows",
  "windows": ["main", "annotation"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-write-text-file",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-image"
  ]
}
