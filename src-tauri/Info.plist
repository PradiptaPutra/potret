<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSScreenCaptureUsageDescription</key>
	<string>Potret needs screen recording access to capture screenshots.</string>
	<key>NSAppleEventsUsageDescription</key>
	<string>Potret uses Apple Events to copy images to the clipboard.</string>
	<!-- Declare a menu-bar agent so macOS keeps it resident and doesn't reap it when
	     idle with no windows (previously it only set the accessory policy at runtime). -->
	<key>LSUIElement</key>
	<true/>
	<key>NSSupportsAutomaticTermination</key>
	<false/>
</dict>
</plist>
